# Gmail OAuth2 credentials file path (download from Google Cloud Console)
GMAIL_CREDENTIALS_FILE=credentials.json

# OAuth2 token cache (auto-generated on first run – do not commit this file)
GMAIL_TOKEN_FILE=token.json

# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Maximum number of emails to load from the inbox at once
MAX_EMAILS_TO_FETCH=20

# Gmail label to read from (default: INBOX)
DEFAULT_INBOX_LABEL=INBOX
